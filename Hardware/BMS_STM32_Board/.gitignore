# --- KiCad ignore ---

# Backup zips KiCad auto-generates
*-backups/

# Per-user local settings (yours, not the repo's)
*.kicad_prl

# Footprint info cache (regenerated automatically)
fp-info-cache

# Lock files (open-project markers)
*.lck
~*.lck

# Autosave / recovery / editor temp files
_autosave-*
*.kicad_sch-bak
*.kicad_pcb-bak
*~
.history/